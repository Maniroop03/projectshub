{
    "rewrites": [
        {
            "source": "/uploads/(.*)",
            "destination": "/api/uploads/$1"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/((?!api/uploads|api).*)" ,
            "destination": "/index.html"
        }
    ]
}